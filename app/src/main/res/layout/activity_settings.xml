<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ime_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 启用输入法提示 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_enable_ime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/ime_key_background"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="第一步：启用输入法"
                    android:textColor="@color/ime_accent"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="在系统设置中启用「AI智能输入法」，并切换为默认输入法。"
                    android:textColor="@color/ime_key_text"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btn_enable_ime"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:text="前往系统设置启用"
                    android:backgroundTint="@color/ime_accent"
                    android:textColor="@color/ime_background"
                    style="@style/Widget.MaterialComponents.Button" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- AI 引擎配置（新入口） -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/ime_key_background"
            app:cardCornerRadius="12dp"
            app:strokeColor="@color/ime_accent"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="第二步：配置 AI 引擎"
                        android:textColor="@color/ime_accent"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <!-- 当前激活 provider 摘要 -->
                    <TextView
                        android:id="@+id/tv_active_provider_summary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="#88CDD6F4"
                        android:text="未配置" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="支持 Claude / OpenAI / Gemini / DeepSeek 及自定义 OpenAI 兼容接口"
                    android:textColor="@color/ime_key_text"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btn_config_ai"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:text="管理 AI 引擎"
                    android:backgroundTint="@color/ime_generate_btn"
                    android:textColor="@color/ime_background"
                    style="@style/Widget.MaterialComponents.Button" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 无障碍服务（屏幕感知）-->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/ime_key_background"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="第二步：启用屏幕感知（可选）"
                        android:textColor="@color/ime_accent"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_a11y_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="未启用"
                        android:textSize="12sp"
                        android:textColor="#FF888888" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="开启后，AI 能读取你当前屏幕上的对话内容（如微信消息），生成更有针对性的回复。\n\n仅读取文字，不操控任何功能。"
                    android:textColor="@color/ime_key_text"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btn_enable_a11y"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:text="前往无障碍设置启用"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="@color/ime_accent"
                    android:textColor="@color/ime_accent" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 知识库管理 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/ime_key_background"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="第三步：管理知识库"
                    android:textColor="@color/ime_accent"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="添加常用回复模板、个人写作风格，AI 会参考这些内容生成更符合你习惯的文字。"
                    android:textColor="@color/ime_key_text"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btn_manage_kb"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:text="管理知识库"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="@color/ime_accent"
                    android:textColor="@color/ime_accent" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 使用说明 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/ime_key_background"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="使用方式"
                    android:textColor="@color/ime_accent"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="1. 在任意 App 点击输入框，调出本输入法\n2. 在顶部 AI 栏输入你想说的意思（如「感谢对方提供的帮助」）\n3. 点击「生成」，AI 会根据当前场景生成合适的文字\n4. 审核生成内容，点击「发送」注入输入框\n5. 也可以点击「编辑」手动修改后再发送"
                    android:textColor="@color/ime_key_text"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
