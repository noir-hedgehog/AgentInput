<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/ime_key_background">

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/entry_title_hint"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxStrokeColor="@color/ime_accent">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/ime_key_text" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="@string/entry_content_hint"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxStrokeColor="@color/ime_accent">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:maxLines="6"
            android:textColor="@color/ime_key_text" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="@string/entry_tags_hint"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxStrokeColor="@color/ime_accent">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_tags"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/ime_key_text" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- 场景选择 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="适用场景"
        android:textColor="@color/ime_key_text"
        android:textSize="14sp" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_scene"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        app:singleSelection="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_work"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="工作"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="@color/ime_scene_tag_bg"
            android:textColor="@color/ime_key_text" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_chat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="聊天"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="@color/ime_scene_tag_bg"
            android:textColor="@color/ime_key_text" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_email"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="邮件"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="@color/ime_scene_tag_bg"
            android:textColor="@color/ime_key_text" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_general"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="通用"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="@color/ime_scene_tag_bg"
            android:textColor="@color/ime_key_text"
            android:checked="true" />

    </com.google.android.material.chip.ChipGroup>

</LinearLayout>
